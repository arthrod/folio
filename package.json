{
  "name": "@stll/folio",
  "version": "0.1.0",
  "description": "A modern .docx-compatible document editor for the browser, built on ProseMirror and React.",
  "keywords": [
    "document-editor",
    "docx",
    "editor",
    "ooxml",
    "prosemirror",
    "react",
    "word",
    "wysiwyg"
  ],
  "homepage": "https://github.com/stella/folio",
  "bugs": {
    "url": "https://github.com/stella/folio/issues"
  },
  "license": "Apache-2.0",
  "author": "STLL",
  "repository": {
    "type": "git",
    "url": "https://github.com/stella/folio.git"
  },
  "type": "module",
  "packageManager": "bun@1.3.14",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core/index.ts",
    "./markdown": "./src/core/markdown/index.ts",
    "./server": "./src/server.ts",
    "./editor.css": "./src/styles/editor.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "git clean -xdf dist .cache .turbo node_modules",
    "build": "rm -rf dist && tsdown && bun scripts/build-css.ts",
    "build:css": "bun scripts/build-css.ts",
    "prepack": "bun run build",
    "pack:dry-run": "bun pm pack --dry-run",
    "validate-dist": "bun scripts/validate-dist.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.build.json",
    "lint": "bun --bun oxlint -c oxlint.config.ts src scripts test",
    "lint:fix": "bun --bun oxlint -c oxlint.config.ts --fix src scripts test",
    "format": "oxfmt .",
    "perf": "bun scripts/profile-editor.ts",
    "test": "bun test src",
    "test:property": "bun test $(grep -rlF 'fc.assert' src --include='*.test.ts')",
    "test:visual": "bunx playwright test",
    "test:visual:update": "bunx playwright test --update-snapshots",
    "test:visual:report": "bunx playwright show-report"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@fontsource/arimo": "^5.2.8",
    "@fontsource/caladea": "^5.2.8",
    "@fontsource/carlito": "^5.2.8",
    "@fontsource/cousine": "^5.2.7",
    "@fontsource/noto-sans-arabic": "^5.2.7",
    "@fontsource/tinos": "^5.2.7",
    "@stll/docx-core": "^0.1.0",
    "@stll/docx-utils": "^0.1.0",
    "@stll/template-conditions": "^0.1.0",
    "better-result": "2.9.2",
    "csstype": "^3.1.3",
    "fast-xml-parser": "^5.9.3",
    "jszip": "3.10.1",
    "lucide-react": "1.21.0",
    "marked": "^18.0.5",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-gapcursor": "^1.4.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.9",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8",
    "utif2": "^4.1.0",
    "valibot": "1.4.1",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@stll/oxlint-config": "0.3.0",
    "@types/bun": "1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260624.1",
    "fast-check": "^4.8.0",
    "lightningcss": "1.32.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "0.22.3",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "use-intl": ">=4.0.0"
  }
}
